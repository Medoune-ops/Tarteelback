# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
# Comma-separated list of allowed origins for CORS. Use * for dev only.
CORS_ORIGINS=*

# ─── Database (matches docker-compose.yml) ───────────────────────────────────
# In production, bound the per-instance pool so (instances × connection_limit)
# stays under Postgres max_connections (ideally behind PgBouncer in transaction
# mode). Example: ...?schema=public&connection_limit=10&pool_timeout=20
DATABASE_URL="postgresql://tarteel:tarteel@localhost:5432/tarteel?schema=public"

# ─── Redis (optional but recommended for scale) ──────────────────────────────
# When set: distributed rate-limit, content cache, league sorted-sets, locks,
# and the job queue. When unset: the app still works (in-memory rate-limit +
# SQL-only ranking) — fine for a single instance / local dev.
REDIS_URL="redis://localhost:6379"
# Content cache TTL (sections/sourates/versets/lessons are near-immutable).
CONTENT_CACHE_TTL_SECONDS=3600

# ─── JWT / Auth ──────────────────────────────────────────────────────────────
# Generate strong, DISTINCT secrets (>=32 chars). In production the server
# refuses to boot if these look like placeholders or are equal.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=dev-only-access-0123456789abcdef0123456789abcdef
JWT_REFRESH_SECRET=dev-only-refresh-fedcba9876543210fedcba9876543210
# Access token lifetime (short). Format accepted by @fastify/jwt / ms.
ACCESS_TOKEN_TTL=15m
# Refresh token lifetime in days (sliding window; rotated on each refresh).
REFRESH_TOKEN_TTL_DAYS=90

# ─── Game rules (server-authoritative; defaults match the front store) ───────
MAX_HEARTS=5
# Heart regeneration interval in milliseconds (4h).
HEART_REGEN_MS=14400000
# XP multiplier for premium users.
PREMIUM_XP_MULTIPLIER=2

# ─── Default content language / i18n ─────────────────────────────────────────
# Fallback translation language used when the user's language is unavailable.
DEFAULT_LANG=en

# ─── Quran import (prisma/importQuran.ts) ────────────────────────────────────
QURAN_API_BASE=https://api.quran.com/api/v4
# Quran.com resource ids for the editions to import.
# Translation resource ids (comma separated) -> imported into VersetTraduction.
#   131 = Dr. Mustafa Khattab (EN), 136 = Hamidullah (FR), 77/78 = Saheeh Intl, etc.
QURAN_TRANSLATION_IDS=131,136
# Map of translation resource id -> language code (id:lang,...).
QURAN_TRANSLATION_LANGS=131:en,136:fr
# Transliteration resource id (Latin). 57 = Transliteration (en) on quran.com.
QURAN_TRANSLITERATION_ID=57
# Recitation id for per-ayah audio (7 = Mishari Rashid al-Afasy).
QURAN_RECITATION_ID=7
# Limit the import to the first N surahs from the end (Juz Amma fast dev seed).
# Leave empty to import all 114 surahs.
QURAN_IMPORT_LIMIT=

# ─── Password reset email (Resend) ───────────────────────────────────────────
# When RESEND_API_KEY is empty, the reset link is logged to the console instead
# of emailed (dev-friendly). Set it in production to actually send mail.
RESEND_API_KEY=
# Verified sender. Until you verify a domain in Resend, "onboarding@resend.dev"
# works for testing.
MAIL_FROM=Tarteel <onboarding@resend.dev>
# Where the reset link points. A deep link into the app (expo-router screen
# reset-password) or a web URL. The token is appended as ?token=...
APP_RESET_URL=tarteel://reset-password
# Reset-token lifetime in minutes.
PASSWORD_RESET_TTL_MINUTES=30

# ─── Billing (mock provider) ─────────────────────────────────────────────────
# Mock only: no real Stripe. Prices are informative for the API/receipts.
PREMIUM_PRICE_MONTHLY=1.52
PREMIUM_PRICE_YEARLY=15.24
STREAK_REPAIR_PRICE=0.87
BILLING_CURRENCY=EUR
