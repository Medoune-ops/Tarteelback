// Tarteel backend — Prisma schema
// =============================================================================
// Design notes (the two trickiest mechanics):
//
//  HEARTS (lives). We do NOT store a running timer. We store `hearts` and a
//  single anchor `lastHeartLossAt`. Regeneration is derived on read:
//      regenerated = floor((now - lastHeartLossAt) / HEART_REGEN_MS)
//  capped at MAX_HEARTS; when hearts reach MAX we reset `lastHeartLossAt = null`.
//  This makes the rule fully server-authoritative and timezone-independent
//  (pure UTC duration), and survives the client being offline. It mirrors the
//  front store (`computeHearts`) so the contract is identical.
//
//  STREAK. `streak` is the current flame. `streakFrozen` marks "missed one
//  day, not broken yet". `lastStreakValue` snapshots the streak right before a
//  break so a paid `repair-streak` can restore it. `lastActivityDate` (a date
//  in the user's timezone) is the source of truth for recomputation on app
//  open — we never trust a client-sent date.
//
//  i18n — TWO patterns coexist, pick deliberately for any NEW text field:
//
//   1) Separate table keyed by `langue` (VersetTraduction, VersetTranslitteration).
//      Use this when a language could be ADDED later without a migration, or
//      when there can be multiple sources/variants per language.
//
//   2) `Json` column shaped `{ fr: string, en: string, ... }`, resolved by
//      `resolveI18n()` in content.serializer.ts given the request's `lang`.
//      Use this for short UI-ish text authored alongside the content itself
//      (Section.titre/sousTitre, Lesson.titre, LessonStep.payload.consigne).
//
//   ⚠️ RULE: any NEW text field a user reads (titles, labels, consignes,
//   generated copy) MUST use one of these two patterns from the day it's
//   added — never a plain `String` "for now". Retrofitting i18n onto a
//   String column later means: a Prisma migration, re-running every content
//   generator, AND remembering to actually deploy the serializer change
//   (see git history: the {fr,en} migration shipped to the DB once before
//   the code that resolves it was ever committed — the API served raw JSON
//   as visible text for a while as a result). Decide the shape up front.
//
//   Whichever pattern you pick, update content.serializer.ts's `resolveI18n`
//   call sites AND double-check with `git push` + a live `curl` against the
//   deployed API — a passing local typecheck does not mean it's live.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  user
  admin
}

/// A section of the back-office web app an AdminUser can be granted access to.
/// Kept as an enum (not a free-text string) so a typo can't silently grant no
/// access — the granular ("view/edit") flag lives on AdminPermission.
enum AdminModule {
  overview
  users
  content
  monetization
  analytics
  push_announcements
  team
}

enum UserLevel {
  debutant
  alphabet
  lent
  fluent
}

enum Objectif {
  lire
  hifz
  tafsir
  complet
}

enum LessonState {
  locked
  active
  completed
}

enum StepType {
  discovery
  written
  voice
  ordering
  matching
}

enum RevisionState {
  maitrise
  revoir
  difficile
}

enum TransactionType {
  premium_subscription
  streak_repair
  gem_pack
  heart_pack // achat direct de cœurs avec de l'argent (paiement mock)
}

/// Why a user's gem balance changed. Positive amounts = earnings (economy
/// source), negative = spends (economy sink). One GemTransaction row per
/// change so the earned:spent ratio KPI can be computed from the ledger.
enum GemReason {
  lesson_complete // +10
  lesson_perfect // +20 (0 mistakes, replaces lesson_complete)
  daily_streak // +5 per maintained day (+ bonus tiers)
  streak_bonus // +50 at D7, +150 at D30
  league_promotion // +100..500 depending on the reached tier
  daily_chest // hearts rolled while already full → converted to gems
  pack_purchase // + pack size (paid with real money)
  heart_refill // -350
  streak_freeze // -200
  double_xp // -100
  admin_grant // back office: an owner/member manually granted gems to a user
}

enum TransactionStatus {
  pending
  success
  failed
  refunded
}

// ─── User & session ──────────────────────────────────────────────────────────

model User {
  id             String  @id @default(cuid())
  email          String  @unique
  passwordHash   String? // null when the account is OAuth-only
  displayName    String
  // Pseudo public (ligues, classements) — le nom complet reste privé au
  // profil. Optionnel pour les comptes créés avant son introduction :
  // l'affichage retombe alors sur displayName. Stocké en minuscules.
  username       String? @unique
  avatarInitials String  @default("")
  role           Role    @default(user)

  // Profile / onboarding
  level          UserLevel @default(debutant)
  objectif       Objectif  @default(lire)
  dailyMinutes   Int       @default(10)
  onboardingDone Boolean   @default(false)
  timezone       String    @default("UTC") // e.g. "Africa/Dakar" — local day/midnight
  language       String    @default("en") // preferred translation language
  // Voice exercises & recordings toggle (Settings → Voix & enregistrements).
  voiceEnabled   Boolean   @default(true)

  // Premium
  // `isPremium`/`premiumUntil` = premium EFFECTIF (personnel OU familial),
  // matérialisé par syncUserState pour que tous les contrôles existants
  // (isPremiumActive) restent valables sans changement.
  isPremium            Boolean   @default(false)
  premiumUntil         DateTime?
  // Abonnement PERSONNEL de ce compte (indépendant du plan familial). Sert de
  // source pour recalculer le premium effectif. Rétro-rempli = premiumUntil.
  personalPremiumUntil DateTime?

  // Stats / hearts / streak (kept on User for atomic 1-1 updates)
  // Single XP counter — resets to 0 every week alongside the league rollover
  // (no separate lifetime total: see league.cron.ts).
  weeklyXp        Int       @default(0)
  hearts          Int       @default(5)
  // Anchor for heart regeneration; null when hearts are full.
  lastHeartLossAt DateTime?

  streak           Int       @default(0)
  streakFrozen     Boolean   @default(false)
  // Snapshot of the streak just before a break, for paid restoration.
  lastStreakValue  Int       @default(0)
  // Local-day date of the last completed activity (source of truth for streak).
  lastActivityDate DateTime?

  // Notification preferences (push). Defaults on; user can opt out per type.
  notifDailyReminder  Boolean @default(true)
  notifStreakAlert    Boolean @default(true)
  // Optional preferred local hour (0–23) for the daily learning reminder.
  reminderHour        Int     @default(19)
  // Marks the last local-day a daily reminder was sent, to avoid duplicates.
  lastDailyReminderOn String?
  lastStreakAlertOn   String?

  // Gems (virtual currency) — server-authoritative balance. Every change goes
  // through a GemTransaction row (ledger) inside the same DB transaction.
  gems             Int       @default(0)
  // Purchased streak-freeze inventory (200 gems each, max 2 held). Consumed
  // automatically when missed days would otherwise break the streak. Premium
  // (Plus) users never consume any: their freezes are unlimited.
  streakFreezes    Int       @default(0)
  // Double-XP boost (100 gems) active until this instant; null = no boost.
  doubleXpUntil    DateTime?
  // "Réviser pour regagner" gate: local-day + how many hearts were regained
  // through review sessions that day (max 2/day).
  reviewHeartsDay  String?
  reviewHeartsUsed Int       @default(0)

  // Rewards / engagement (server-authoritative; front mirrors store fields).
  // User-set streak goal (null = none). Reward credited once on reach.
  streakGoal   Int?
  // Local-day (YYYY-MM-DD) of the last claimed daily chest (1 per local day).
  lastChestDay String?

  // Parrainage : code de partage unique (généré à la demande) + qui a parrainé
  // ce compte. Un compte ne peut être parrainé qu'UNE fois (referredById figé
  // au 1er redeem) → le parrain et le filleul reçoivent chacun des cœurs bonus.
  referralCode String? @unique
  referredById String?
  referredBy   User?   @relation("UserReferrals", fields: [referredById], references: [id])
  referrals    User[]  @relation("UserReferrals")

  // Soft-ban from the back office (src/modules/adminUsers). Non-null = the
  // account is blocked from authenticating (see auth.service.login). Kept
  // separate from `role` — banning is a moderation action, not a permission
  // change. Reversible: /admin/users/:id/unban just clears both fields.
  bannedAt     DateTime?
  bannedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens     RefreshToken[]
  lessonProgress    LessonProgress[]
  sourateRevisions  SourateRevision[]
  chainProgress     SourateChainProgress[]
  lettreRevisions   LettreRevision[]
  leagueMemberships LeagueMembership[]
  transactions      Transaction[]
  deviceTokens      DeviceToken[]
  podiumRewards     PodiumReward[]
  passwordResets    PasswordResetToken[]
  activityDays      ActivityDay[]
  gemTransactions   GemTransaction[]

  // Plan familial (foyer) : un compte possède au plus un foyer (owner) et
  // appartient à au plus un foyer (membership).
  ownedHousehold  Household?            @relation("HouseholdOwner")
  householdMember HouseholdMember?
  sentInvitations HouseholdInvitation[] @relation("InvitedBy")
  pendingGifts    PendingGift[]
  supportMessages SupportMessage[]

  @@index([weeklyXp])
  @@index([bannedAt])
  @@index([createdAt])
}

/// Un cadeau admin (cœurs/gemmes/premium) en attente d'affichage côté client.
/// Le front poll GET /me/pending-gift toutes les ~15s tant que l'app est
/// ouverte (fonctionne sur Expo Go, pas besoin de push/build natif) ; dès
/// qu'il en trouve un, il joue l'animation cadeau puis appelle
/// POST /me/pending-gift/:id/ack pour le marquer vu (jamais rejoué).
model PendingGift {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String // 'hearts' | 'gems' | 'premium'
  amount    Int
  createdAt DateTime  @default(now())
  seenAt    DateTime?

  @@index([userId, seenAt])
}

/// Message support envoyé depuis Paramètres → Support (réclamation ou
/// suggestion, texte libre, pas de catégorie). Visible dans le back-office
/// (GET /backoffice/support/messages), avec un statut lu/non lu que l'admin
/// peut basculer (POST /backoffice/support/messages/:id/read) — pas d'autre
/// workflow, l'admin répond hors système (mailto:).
model SupportMessage {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([createdAt])
  @@index([read])
}

/// Foyer (plan familial). Un propriétaire (owner), jusqu'à HOUSEHOLD_MAX_MEMBERS
/// membres (owner inclus). Quand `subscriptionActive` et `subscriptionUntil` est
/// dans le futur, TOUS les membres bénéficient du premium (matérialisé sur
/// chaque User via recomputePremium).
model Household {
  id                 String    @id @default(cuid())
  ownerId            String    @unique
  owner              User      @relation("HouseholdOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  subscriptionActive Boolean   @default(false)
  subscriptionUntil  DateTime?
  plan               String? // "famille_mensuel" | "famille_annuel"
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  members     HouseholdMember[]
  invitations HouseholdInvitation[]
}

/// Appartenance d'un compte à un foyer. Un compte appartient à AU PLUS un foyer
/// (userId unique). Le propriétaire a aussi une ligne membre (role "owner").
model HouseholdMember {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("member") // "owner" | "member"
  joinedAt    DateTime  @default(now())

  @@unique([householdId, userId])
  @@index([householdId])
}

/// Invitation à rejoindre un foyer (par email). Expire après INVITE_TTL_DAYS.
model HouseholdInvitation {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  email       String // email invité (minuscules)
  token       String    @unique @default(cuid())
  status      String    @default("pending") // pending | accepted | declined | expired | cancelled
  invitedById String
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  respondedAt DateTime?

  @@index([householdId])
  @@index([email])
  @@index([status])
}

/// One row per LOCAL day the user was active (completed at least one lesson).
/// `day` is the user's local calendar day as "YYYY-MM-DD" (same notion as the
/// streak's local-day key), so the profile calendar can highlight EXACTLY the
/// days studied — including isolated days and past months. Idempotent per day
/// via the unique (userId, day).
model ActivityDay {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  day    String // "YYYY-MM-DD" in the user's timezone

  createdAt DateTime @default(now())

  @@unique([userId, day])
  @@index([userId, day])
}

/// Single-use, short-lived password-reset token. We store only a SHA-256 hash
/// of the token (the plaintext goes out in the email link, never persisted),
/// mirroring the RefreshToken approach so a leaked DB can't be replayed.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// A weekly top-3 finish whose XP reward can be claimed once.
/// Created by the league rollover; mirrors the front `PodiumEntry`.
model PodiumReward {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Stable id shown to the client (e.g. "w23"); unique per user.
  ref       String
  semaine   Int
  ligue     String // bronze | argent | or | emeraude | diamant
  rang      Int // 1 | 2 | 3
  xp        Int // XP accumulated that week
  reward    Int // XP reward for this rank (500/300/150)
  claimedAt DateTime?
  createdAt DateTime  @default(now())

  @@unique([userId, ref])
  @@index([userId])
}

/// One Expo push token per device/installation, for sending notifications.
model DeviceToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Expo push token, e.g. "ExponentPushToken[xxxxxxxx]".
  token      String    @unique
  deviceId   String // installation id (same notion as RefreshToken.deviceId)
  platform   String? // "ios" | "android" | "web"
  // Cleared/disabled when Expo reports the token as no longer valid.
  disabledAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
}

/// Persistent session: long-lived, hashed, per-device refresh tokens.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // We store only a hash of the token (never the token itself).
  tokenHash String    @unique
  deviceId  String // identifies the installation/device
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([userId, deviceId])
  // Supports session listing/cleanup filtered by expiry.
  @@index([expiresAt])
}

// ─── Back-office (web admin panel) ────────────────────────────────────────────
//
// Deliberately separate from `User`/`Role`: back-office members are a distinct
// population from mobile app users (different login surface, different JWT
// audience — see plugins/adminAuth.ts — different session lifetime). Mixing
// the two would mean every mobile-auth code path has to reason about whether
// a "user" might secretly be able to open the back-office, which is exactly
// the kind of privilege-escalation bug this split avoids.
//
// There is exactly one super-admin flag (`isOwner`): only an owner can invite
// members, revoke them, or change anyone's password. Everyone else's access is
// entirely described by their AdminPermission rows — no separate "role" enum,
// because the back-office UI grants access per module (view/edit), not by a
// fixed named role.

/// A back-office account. Created exclusively by an owner (no self-signup) —
/// see AdminAuthService.inviteMember. The owner hands the plaintext password
/// to the member out of band (e.g. in person); it is never emailed.
model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  displayName  String
  // Only an owner can invite members / reset passwords / manage permissions.
  // There is intentionally no multi-owner promotion flow yet — ownership is
  // seeded, not grantable through the API.
  isOwner      Boolean   @default(false)
  disabledAt   DateTime? // soft "revoke access" without deleting history
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  permissions   AdminPermission[]
  refreshTokens AdminRefreshToken[]
  activityLogs  AdminActivityLog[]

  @@index([disabledAt])
}

/// One row per (member, module): what they're allowed to do there. Absence of
/// a row means no access at all (default-deny). `canEdit` implies `canView`
/// is also true — enforced in AdminAuthService, not at the DB layer.
model AdminPermission {
  id          String      @id @default(cuid())
  adminUserId String
  adminUser   AdminUser   @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  module      AdminModule
  canView     Boolean     @default(true)
  canEdit     Boolean     @default(false)

  @@unique([adminUserId, module])
}

/// Persistent back-office session — same "opaque + hashed" design as the
/// mobile RefreshToken (see core/tokens.ts), but kept on its own model/table
/// so mobile and back-office sessions can never be confused or cross-revoked.
model AdminRefreshToken {
  id          String    @id @default(cuid())
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  deviceId    String
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([adminUserId])
  @@index([adminUserId, deviceId])
  @@index([expiresAt])
}

/// Audit trail shown on the "Journal d'activité" screen: every login/logout
/// and every mutating action taken from the back-office. Write-only from the
/// app's perspective (no update/delete endpoint) so it stays trustworthy.
model AdminActivityLog {
  id          String    @id @default(cuid())
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  // Machine-readable action key, e.g. "login", "logout", "user.ban",
  // "monetization.price_updated". The UI renders a French label from this.
  action      String
  // Free-form context for the log line, e.g. { targetUserId, oldValue, newValue }.
  // Kept as Json rather than a fixed column set — the set of loggable actions
  // grows with every new back-office feature.
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime  @default(now())

  @@index([adminUserId, createdAt])
  @@index([action])
}

// ─── Content (admin-managed) ─────────────────────────────────────────────────

model Section {
  id           String  @id @default(cuid())
  ordre        Int     @unique
  hizb         Int? // null for the alphabet section
  kicker       String
  // {fr,en} translatable text — resolved by content.serializer.ts per `lang`.
  // `kicker` stays a plain String: "SECTION N" is language-neutral.
  titre        Json
  sousTitre    Json
  couleur      String
  degradeStart String
  degradeEnd   String
  headerIcon   String
  // Back-office draft/published toggle. A draft section (and its lessons) is
  // still returned to admin tooling but hidden from the public /sections
  // listing — lets content be prepared ahead of its public release.
  publie       Boolean @default(true)

  lessons      Lesson[]
  // Surahs shown as context badges on the section.
  sourateLinks SectionSourate[]

  @@index([hizb])
  @@index([publie])
}

/// Join table: which surahs belong (contextually) to a section, in order.
model SectionSourate {
  id        String  @id @default(cuid())
  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sourateId String
  sourate   Sourate @relation(fields: [sourateId], references: [id], onDelete: Cascade)
  ordre     Int

  @@unique([sectionId, sourateId])
  @@index([sectionId])
}

model Lesson {
  id            String  @id @default(cuid())
  sectionId     String
  section       Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  ordre         Int
  // {fr,en} translatable text — resolved by content.serializer.ts per `lang`.
  titre         Json
  iconType      String  @default("star")
  // Numéro (1–114) de la sourate enseignée par cette leçon, si applicable.
  // Rempli au seed. Sert à marquer "déjà mémorisé" à l'onboarding (skip du
  // point de départ) et, plus tard, aux révisions. null pour les leçons de
  // lettres de l'alphabet.
  sourateNumero Int?
  // Plage de versets (1-based, inclusive) enseignée par cette leçon — 1 ou 2
  // versets consécutifs selon `groupVerses` (lessonBuilder.ts). Rempli au seed
  // pour les leçons de sourates ; null pour les leçons de lettres de
  // l'alphabet. Permet à la révision guidée de rejouer l'ordre RÉEL
  // d'apprentissage (cf. core/revisionChain.ts), indépendamment du découpage
  // arithmétique par blocs de 10 utilisé par le SRS classique (SourateRevision).
  versetDebut   Int?
  versetFin     Int?

  steps     LessonStep[]
  progress  LessonProgress[]
  revisions LettreRevision[]

  @@unique([sectionId, ordre])
  @@index([sectionId])
  @@index([sourateNumero])
}

model LessonStep {
  id       String   @id @default(cuid())
  lessonId String
  lesson   Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  ordre    Int
  type     StepType
  // Shape depends on `type` (see src/modules/lessons/lesson.types.ts):
  //  discovery: { arabe, translitteration, traduction, audioUrl }
  //  written:   { consigne, arabe, translitteration?, options:[{id,text}], bonneReponse }
  //  voice:     { arabe, translitteration, traduction, audioUrl, seuilReussite }
  payload  Json

  @@unique([lessonId, ordre])
  @@index([lessonId])
}

// ─── Quran reference data ────────────────────────────────────────────────────

model Sourate {
  id            String  @id @default(cuid())
  numero        Int     @unique // 1–114
  nom           String // Latin / common name, e.g. "Al-Fatiha"
  nomArabe      String
  nombreVersets Int
  hizb          Int // hizb the surah starts in (used to build sections)
  // Revelation place, useful metadata from quran.com (makkah/madinah).
  revelation    String?

  versets       Verset[]
  sectionLinks  SectionSourate[]
  revisions     SourateRevision[]
  chainProgress SourateChainProgress[]

  @@index([hizb])
}

model Verset {
  id         String  @id @default(cuid())
  sourateId  String
  sourate    Sourate @relation(fields: [sourateId], references: [id], onDelete: Cascade)
  numero     Int // ayah number within the surah
  texteArabe String
  audioUrl   String?

  traductions       VersetTraduction[]
  translitterations VersetTranslitteration[]
  mots              VersetMot[]

  @@unique([sourateId, numero])
  @@index([sourateId])
}

/// One word of a verse, with its own recitation audio (word-by-word). Lets the
/// UI play EXACTLY the word shown (not the whole verse). `position` is 1-based
/// and follows the Mushaf order. Filled from quran.com (`words[].audio_url`).
model VersetMot {
  id         String  @id @default(cuid())
  versetId   String
  verset     Verset  @relation(fields: [versetId], references: [id], onDelete: Cascade)
  position   Int // 1-based index of the word within the verse
  texteArabe String
  audioUrl   String?

  @@unique([versetId, position])
  @@index([versetId])
}

/// Per-language meaning shown under a verse (the user's language decides which).
model VersetTraduction {
  id       String @id @default(cuid())
  versetId String
  verset   Verset @relation(fields: [versetId], references: [id], onDelete: Cascade)
  langue   String // ISO code: "fr", "en", "ar", …
  texte    String
  source   String // edition name, e.g. "Hamidullah", "Saheeh International"

  @@unique([versetId, langue])
  @@index([langue])
}

/// Per-language Latin transliteration (may differ by language convention).
model VersetTranslitteration {
  id       String @id @default(cuid())
  versetId String
  verset   Verset @relation(fields: [versetId], references: [id], onDelete: Cascade)
  langue   String
  texte    String
  source   String

  @@unique([versetId, langue])
  @@index([langue])
}

// ─── Progression ─────────────────────────────────────────────────────────────

model LessonProgress {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  etat        LessonState @default(locked)
  score       Int         @default(0)
  completedAt DateTime?

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId, etat])
}

/// SRS data, désormais PAR SEGMENT (bloc de SEGMENT_SIZE versets consécutifs,
/// cf. core/revision.ts) plutôt que par sourate entière : une sourate longue
/// (ex. Al-Baqara, 286 versets) a plusieurs lignes, une par bloc, pour que les
/// segments fragiles et maîtrisés soient suivis indépendamment.
model SourateRevision {
  id                      String        @id @default(cuid())
  userId                  String
  user                    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourateId               String
  sourate                 Sourate       @relation(fields: [sourateId], references: [id], onDelete: Cascade)
  // Index 0-based du bloc de versets au sein de la sourate (0 = versets 1..N).
  segmentIndex            Int           @default(0)
  score                   Int           @default(0)
  etat                    RevisionState @default(revoir)
  prochaineRevision       DateTime?
  derniereRevision        DateTime?
  intervalleJours         Int           @default(1)
  // Anti-triche "réviser pour regagner" : marque la dernière `derniereRevision`
  // déjà récompensée par un cœur, pour qu'une même session complétée ne
  // puisse pas être rejouée plusieurs fois (cf. gem.service.ts).
  derniereRecompenseCoeur DateTime?

  @@unique([userId, sourateId, segmentIndex])
  @@index([userId])
  @@index([sourateId])
}

/// Curseur de la RÉVISION GUIDÉE (chaînage progressif) d'une sourate, séparé
/// du SRS classique (SourateRevision, blocs de SEGMENT_SIZE) : ici on rejoue
/// l'ordre RÉEL d'apprentissage leçon par leçon (`Lesson.ordre`, 1-2 versets
/// enseignés à la fois via `versetDebut`/`versetFin`), en faisant grossir un
/// bloc consolidé jusqu'à couvrir toute la sourate. `lessonsConsolidees`
/// compte combien de leçons (dans l'ordre) sont déjà intégrées au bloc
/// consolidé ; la prochaine étape apprend/réintègre la leçon suivante.
model SourateChainProgress {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourateId          String
  sourate            Sourate  @relation(fields: [sourateId], references: [id], onDelete: Cascade)
  lessonsConsolidees Int      @default(0)
  terminee           Boolean  @default(false)
  updatedAt          DateTime @updatedAt

  @@unique([userId, sourateId])
  @@index([userId])
}

/// SRS des leçons d'alphabet/harakat (Lesson.sourateNumero = null) — même
/// mécanique que SourateRevision (score 0-100, planning), mais liée à une
/// Lesson plutôt qu'à une Sourate : ces leçons n'enseignent pas un verset.
model LettreRevision {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId          String
  lesson            Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  score             Int           @default(0)
  etat              RevisionState @default(revoir)
  prochaineRevision DateTime?
  derniereRevision  DateTime?
  intervalleJours   Int           @default(1)

  @@unique([userId, lessonId])
  @@index([userId])
}

// ─── Leagues ─────────────────────────────────────────────────────────────────

model League {
  id     String @id @default(cuid())
  nom    String // Bronze, Argent, Or, Émeraude …
  niveau Int // rank tier (1 = lowest)
  ordre  Int    @unique

  weeks LeagueWeek[]
}

model LeagueWeek {
  id            String    @id @default(cuid())
  leagueId      String
  league        League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  numeroSemaine Int
  dateDebut     DateTime
  dateFin       DateTime
  // Set when the weekly rollover has processed this week. Makes the rollover
  // idempotent: a re-run (retry/double scheduler) skips already-closed weeks.
  closedAt      DateTime?

  memberships LeagueMembership[]

  @@unique([leagueId, numeroSemaine])
  @@index([leagueId])
  // Finding the active week ("now between dateDebut and dateFin") and ended
  // weeks for the rollover.
  @@index([dateDebut, dateFin])
  @@index([dateFin, closedAt])
}

model LeagueMembership {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  leagueWeekId String
  leagueWeek   LeagueWeek @relation(fields: [leagueWeekId], references: [id], onDelete: Cascade)
  weeklyXp     Int        @default(0)
  rang         Int? // computed snapshot; recomputed on XP changes
  joinedAt     DateTime   @default(now())

  @@unique([userId, leagueWeekId])
  @@index([leagueWeekId, weeklyXp])
}

/// Gem ledger: one row per balance change (earn or spend). The `User.gems`
/// column is the authoritative running balance; this ledger is the audit trail
/// and powers the earned:spent economy KPI.
model GemTransaction {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Signed delta: positive = earned, negative = spent.
  amount    Int
  reason    GemReason
  // Optional link to the source (lessonId, week ref, money Transaction id…).
  ref       String?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

// ─── Billing ─────────────────────────────────────────────────────────────────

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType
  montant     Decimal           @db.Decimal(10, 2)
  devise      String            @default("EUR")
  statut      TransactionStatus @default(pending)
  providerRef String? // mock provider reference OR DexPay checkout session reference
  createdAt   DateTime          @default(now())

  // Référence unique envoyée à DexPay comme `reference` de la checkout
  // session — sert à retrouver la Transaction depuis le webhook
  // checkout.completed/failed/cancelled (providerRef reste libre pour un id
  // opaque du provider, reference est TOUJOURS la nôtre, générée avant l'appel
  // DexPay). Null pour les anciennes transactions mock pré-DexPay.
  reference String? @unique

  // Paramètres nécessaires pour REJOUER l'effet métier quand le webhook
  // confirme le paiement (ex: { plan: 'annuel' } pour premium_subscription,
  // { pack: 'p3000' } pour gem_pack) — le webhook n'a que la Transaction en
  // main, pas la requête HTTP d'origine. Null pour heart_pack/streak_repair
  // (montant fixe, pas de paramètre).
  payload Json?

  // billing.status() filters by userId and orders by createdAt desc.
  @@index([userId, createdAt])
}

// ─── Remote config ───────────────────────────────────────────────────────────

/**
 * Singleton (single row, id fixed to "singleton") holding remote-toggleable
 * product flags — no redeploy needed to flip them. `paymentsEnabled` exists
 * because app store review sometimes requires payment UI to stay hidden
 * until a release is approved: the back-office (Monétisation) can hide it
 * before submission and switch it back on afterwards. Read via public
 * GET /config (no auth — the app needs it before login), written via
 * PATCH /backoffice/config (admin only).
 */
model AppConfig {
  id              String   @id @default("singleton")
  paymentsEnabled Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}
