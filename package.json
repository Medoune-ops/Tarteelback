{
  "name": "tarteel-backend",
  "version": "1.0.0",
  "description": "Backend API for Tarteel — a Quran-learning app (Duolingo-style). Fastify + Prisma + PostgreSQL.",
  "main": "dist/server.js",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "seed:quran": "tsx prisma/importQuran.ts",
    "seed:lessons": "tsx prisma/generateLessons.ts",
    "seed:alphabet": "tsx prisma/generateAlphabet.ts",
    "cache:bump": "tsx prisma/bumpCache.ts",
    "jobs:maintenance": "tsx src/jobs/maintenance.ts",
    "jobs:rollover": "tsx src/jobs/maintenance.ts rollover",
    "jobs:reminders": "tsx src/jobs/maintenance.ts reminders",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@prisma/client": "^6.2.1",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.11.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
